{
  "name": "philharmony/http-message",
  "description": "PSR-7 HTTP message implementation with Enum typing for Philharmony",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "psr",
    "psr-7",
    "http",
    "http-message",
    "request",
    "response",
    "stream",
    "uri"
  ],
  "homepage": "https://github.com/philharmonytech/http-message",
  "authors": [
    {
      "name": "Vyacheslav86RUS",
      "email": "ProSlavon86@gmail.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "psr/http-message": "^2.0.0",
    "philharmony/http-enum": "^1.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.0",
    "friendsofphp/php-cs-fixer": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "Philharmony\\Http\\Message\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Philharmony\\Http\\Message\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-clover coverage.xml --coverage-html coverage --coverage-filter src",
    "phpstan": "phpstan analyse --memory-limit=1G",
    "cs-check": "php-cs-fixer fix --dry-run --allow-risky=yes",
    "cs-fix": "php-cs-fixer fix --allow-risky=yes"
  },
  "config": {
    "sort-packages": true
  }
}